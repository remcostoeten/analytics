{
    "name": "remco-analytics",
    "version": "0.0.1",
    "private": true,
    "workspaces": [
        "apps/*",
        "packages/*",
        "packages/ox/*"
    ],
    "scripts": {
        "build": "bun run --filter '*' build",
        "test": "bun run --filter '*' test",
        "typecheck": "bun run --filter '*' typecheck",
        "lint": "bun run -C packages/ox/lint lint:all",
        "fmt": "bun run -C packages/ox/fmt fmt:all",
        "fmt:check": "bun run -C packages/ox/fmt fmt:check:all",
        "dev:ingestion": "bun run -C apps/ingestion dev",
        "deploy": "bun run deploy.ts"
    },
    "devDependencies": {
        "typescript": "catalog:ts"
    },
    "catalogs": {
        "ts": {
            "typescript": "5.6.3"
        },
        "hono": {
            "hono": "4.6.10"
        },
        "oxlint": {
            "oxlint": "0.10.0"
        },
        "oxfmt": {
            "oxfmt": "0.0.0"
        }
    }
}
