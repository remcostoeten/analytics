{
    "name": "remco-analytics",
    "version": "0.0.1",
    "private": true,
    "workspaces": [
        "apps/*",
        "packages/*"
    ],
    "scripts": {
        "prebuild": "bun run scripts/pipeline.ts --no-build",
        "pipeline": "bun run scripts/pipeline.ts",
        "build": "bun run --filter '*' build",
        "test": "bun run --filter '*' test",
        "typecheck": "bun run --filter '*' typecheck",
        "lint": "oxlint apps packages --deny-warnings",
        "fmt": "oxfmt apps packages '!**/dist/**'",
        "fmt:check": "oxfmt --check apps packages '!**/dist/**'",
        "dev:ingestion": "bun run --cwd apps/ingestion dev",
        "ops": "bun run --cwd apps/ingestion ops",
        "ops:build": "bun run --cwd apps/ingestion ops:build",
        "deploy": "bun run deploy.ts"
    },
    "devDependencies": {
        "bun-types": "^1.3.9",
        "typescript": "catalog:ts",
        "oxlint": "catalog:oxlint",
        "oxfmt": "catalog:oxfmt"
    },
    "catalogs": {
        "ts": {
            "typescript": "5.6.3"
        },
        "hono": {
            "hono": "4.6.10"
        },
        "oxlint": {
            "oxlint": "0.10.0"
        },
        "oxfmt": {
            "oxfmt": "0.45.0"
        },
        "drizzle": {
            "drizzle-orm": "^0.36.0",
            "drizzle-kit": "^0.31.9"
        },
        "neon": {
            "@neondatabase/serverless": "^0.10.0"
        }
    }
}
