{
	"name": "@remcostoeten/analytics",
	"version": "1.4.0",
	"description": "Privacy-focused analytics SDK for tracking page views and custom events",
	"keywords": [
		"analytics",
		"gdpr",
		"nextjs",
		"privacy",
		"react",
		"tracking",
		"typescript"
	],
	"license": "MIT",
	"author": "Remco Stoeten",
	"repository": {
		"type": "git",
		"url": "https://github.com/remcostoeten/analytics"
	},
	"files": [
		"dist",
		"README.md"
	],
	"type": "module",
	"sideEffects": false,
	"main": "./dist/index.cjs",
	"module": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/index.js",
			"require": "./dist/index.cjs"
		}
	},
	"publishConfig": {
		"access": "public"
	},
	"scripts": {
		"build": "tsup",
		"dev": "tsup --watch",
		"typecheck": "tsc --noEmit",
		"test": "bun test",
		"test:watch": "bun test --watch",
		"prepublishOnly": "bun run build"
	},
	"devDependencies": {
		"@types/node": "^25.2.3",
		"@types/react": "^19.2.14",
		"bun-types": "^1.3.9",
		"react": "^19.2.4",
		"tsup": "^8.5.1",
		"typescript": "^5.9.3"
	},
	"peerDependencies": {
		"react": "^18.0.0 || ^19.0.0"
	}
}
